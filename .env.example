# ── Database (Aurora RDS PostgreSQL) ──
DATABASE_URL=postgresql://user:pass@cluster.region.rds.amazonaws.com:5432/revenueos

# ── AI (Vercel AI Gateway) ──
AI_GATEWAY_API_KEY=vck_...

# ── Search (Exa) ──
EXA_API_KEY=...

# ── Agent Memory (Honcho Cloud) ──
HONCHO_API_KEY=...

# ── Storage (AWS S3) ──
S3_BUCKET_NAME=your-s3-bucket-name
AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY not needed if using IAM role on Vercel

# ── Auth (AWS Cognito) ──
COGNITO_USER_POOL_ID=ap-southeast-1_xxxxx
COGNITO_CLIENT_ID=xxxxxxxxxxxx

# ── Payments (Stripe) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Demo ──
DEMO_MODE=false
ENCRYPTION_KEY= # 32-byte hex key for AES-256 credential encryption

# HubSpot CRM Integration
HUBSPOT_API_KEY=  # Private app access token (pat-na1-xxx)
HUBSPOT_PORTAL_ID=  # HubSpot portal ID for record URLs
